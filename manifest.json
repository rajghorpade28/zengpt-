{
    "manifest_version": 3,
    "name": "ZenGPT",
    "version": "1.0",
    "description": "Minimize distractions by hiding ChatGPT responses until you're ready to read them.",
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_popup": "src/popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://chat.openai.com/*"
            ],
            "js": [
                "src/content/content.js"
            ],
            "css": [
                "src/content/styles.css"
            ],
            "run_at": "document_start"
        }
    ]
}